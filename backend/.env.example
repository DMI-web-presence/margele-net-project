PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/margele_net
JWT_SECRET=replace-with-a-secure-random-string
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001

# Product image storage mode: local | r2 | auto
# local = always save to backend/uploads
# r2 = only save to Cloudflare R2 and fail if it does not work
# auto = try R2 first, then fall back to local storage
PRODUCT_IMAGE_STORAGE=auto

# Optional: Cloudflare R2 product image storage
# If these are omitted, uploads continue to use local backend/uploads storage.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Example: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Example: https://img.margele.net
R2_PUBLIC_BASE_URL=
R2_REGION=auto
